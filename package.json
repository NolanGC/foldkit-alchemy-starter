{
  "name": "foldkit-alchemy-cloudflare-starter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["backend", "frontend"],
  "scripts": {
    "build": "tsc --noEmit",
    "deploy": "alchemy deploy --stage production",
    "dev": "alchemy dev",
    "clear": "pkill -f 'workerd serve' || true",
    "destroy": "alchemy destroy",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "bun test test/integ.test.ts && bun run --cwd frontend test"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20250805.0",
    "@effect/platform-bun": "4.0.0-beta.88",
    "@effect/platform-node": "4.0.0-beta.88",
    "@effect/sql-pg": "4.0.0-beta.88",
    "alchemy": "^2.0.0-beta.59",
    "drizzle-orm": "1.0.0-rc.1",
    "effect": "4.0.0-beta.88",
    "pg": "^8.13.0",
    "random-word-slugs": "^0.1.7",
    "typescript": "^5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "1.0.0-rc.1",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0"
  },
  "overrides": {
    "@distilled.cloud/cloudflare-runtime": "0.12.0",
    "@distilled.cloud/cloudflare-vite-plugin": "0.12.0",
    "@distilled.cloud/cloudflare-rolldown-plugin": "0.12.0"
  }
}
